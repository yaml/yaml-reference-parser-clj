#!/usr/bin/env ys-0

defn main(*args):
  opts =: parse-args(args)
  when-not opts.from:
    die: 'Usage: generate-yaml-grammar --from <spec.yaml>
          [--rule <top-rule>] [--namespace <prefix>]
          [--no-fuse] [--dump-classes]'
  spec-text =: read(opts.from)
  if opts.dump-classes:
    then: dump-classes(spec-text)
    else:
      say: gen-grammar(spec-text opts.rule opts.namespace opts.no-fuse)

REP-COUNT =: atom(0)

defn parse-args(args):
  opts =: +{:rule 'l-yaml-stream', :namespace 'yaml-parser'}
  parse-args-step: opts args

defn parse-args-step(opts args):
  if args.!:
    then: opts
    else:
      arg =: args.0
      more =: next(args)
      from-opt =: (arg == '--from') || (arg == '-f')
      rule-opt =: (arg == '--rule') || (arg == '-r')
      namespace-opt =: (arg == '--namespace') || (arg == '-n')
      cond:
        from-opt:
          parse-args-step: opts.assoc(:from more.0) next(more)
        rule-opt:
          parse-args-step: opts.assoc(:rule more.0) next(more)
        namespace-opt:
          parse-args-step: opts.assoc(:namespace more.0) next(more)
        arg.starts?('--from='):
          parse-args-step: opts.assoc(:from subs(arg 7)) more
        arg.starts?('--rule='):
          parse-args-step: opts.assoc(:rule subs(arg 7)) more
        arg.starts?('--namespace='):
          parse-args-step: opts.assoc(:namespace subs(arg 12)) more
        arg == '--no-fuse':
          parse-args-step: opts.assoc(:no-fuse true) more
        arg == '--dump-classes':
          parse-args-step: opts.assoc(:dump-classes true) more
        else:
          throw:
            ex-info: +
              "Unknown argument:\ $arg"
              {:arg arg}

defn gen-grammar(spec-text top ns-prefix no-fuse=false):
  spec =: yaml/load(spec-text)
  comments =: get-comments(spec-text)
  nums =: build-nums(spec)
  rule-names =:
    spec:keys.map(key-name).filter(\(_.starts?(':').!))
  classes =:
    when-not no-fuse:
      build-class-table(spec)
  head =: gen-grammar-head(top:rule-name ns-prefix)
  declarations =: rule-names.map(\("  $(rule-name(_))")):text:chomp
  rules =:
    rule-names.map(\(gen-rule(spec nums comments classes _))):join
  =>: |-
    $head
    (declare
    $declarations)

    $rules

defn gen-grammar-head(top-name ns-prefix): |
  ;; This grammar was generated from https://yaml.org/spec/1.2/spec.html

  (ns $ns-prefix.grammar
    (:refer-clojure :exclude [empty])
    (:require [$ns-prefix.parser :as p]
              [$ns-prefix.prelude
               :refer [debug-rule name* from-code-point DEBUG]]))

  (declare $top-name)

  ;; TOP returns the top-level grammar rule as a vector for call to process
  (def TOP
    (name* "TOP"
      (fn TOP-fn [parser]
        ;; Return the top rule as a value that call can process
        [$top-name])
      nil))

  ;; Helper function for auto-detect
  (defn auto_detect [parser n]
    (p/auto-detect parser n))

  (defn auto_detect_indent [parser n]
    (p/auto-detect-indent parser n))

  (defn empty [parser]
    (p/empty-rule parser))

# Character-class fusion. Rules whose bodies reduce to chr/rng/any/but
# algebra over single-codepoint matchers are compiled at generation
# time into one fused matcher over a sorted codepoint range set:
# chr = singleton, rng = range, (any) = union, (---) = difference.
# References to the barrier rules below never fuse into OTHER rules
# (they carry receiver callbacks that must keep firing per call), but
# their own bodies still fuse. Barrier names must track the per-char
# callback rules in src/yaml_parser/parser.cljc (callback-rules).
FUSE-BARRIER =: \{'ns-char' 's-white'}

# Lookahead gates. Rules whose every alternative starts with a known
# small character set (FIRST set, hand-verified against the spec
# productions: every c-ns-tag-property alternative starts with '!',
# c-ns-anchor-property with '&', c-ns-alias-node with '*'). Their
# generated bodies check the next codepoint via p/ahead? and fail
# without executing the combinator subtree when it cannot match.
# Sound because these rules and everything inside their subtrees have
# only got__ receiver callbacks, which fire on success only, and the
# gate never blocks a codepoint that could start a match. Values are
# flat [lo hi ...] codepoint ranges as read by p/ahead?.
GATE-FIRST =:
  +{'c-ns-tag-property' '[0x21 0x21]'
    'c-ns-anchor-property' '[0x26 0x26]'
    'c-ns-alias-node' '[0x2A 0x2A]'}

RULE-REF-RE =: /^(?:b|c|e|l|nb|ns|s)(?:[-+][a-z0-9]+)+$/

defn build-class-table(spec):
  names =: spec:keys.map(key-name).filter(\(_.starts?(':').!))
  init =: +{}
  reduce _ init names:
    fn(table name):
      table.assoc(name rule-class(spec table name))

defn rule-class(spec table name):
  pair =: setm-and-rule(kget(spec name))
  setm =: pair.0
  rule =: pair.1
  cond:
    setm != '': nil
    map?(rule) && kget(rule '(...)'): nil
    else: class-of(table rule contains?(FUSE-BARRIER name))

defn class-of(table expr allow-barrier):
  cond:
    string?(expr): class-of-string(table expr allow-barrier)
    sequential?(expr): class-of-range(expr)
    map?(expr): class-of-hash(table expr allow-barrier)

defn class-of-string(table s allow-barrier):
  hex =: re-matches(/^x([0-9A-F]+)$/ s)
  cond:
    hex:
      cp =: hex-int(hex.1)
      =>: +[[cp cp]]
    re-matches(RULE-REF-RE s):
      when allow-barrier || contains?(FUSE-BARRIER s).!:
        table.get(s)
    s.# == 1:
      cp =: int(first(s))
      =>: +[[cp cp]]

defn class-of-range(expr):
  hexes =:
    (expr.# == 2) &&
    string?(expr.0) && re-matches(/^x[0-9A-F]+$/ expr.0) &&
    string?(expr.1) && re-matches(/^x[0-9A-F]+$/ expr.1)
  when hexes:
    lo =: hex-int(expr.0.drop(1):join)
    hi =: hex-int(expr.1.drop(1):join)
    =>: +[[lo hi]]

defn class-of-hash(table expr allow-barrier):
  keys =: expr:keys
  when keys.# == 1:
    key-str =: key-name(keys.0)
    val =: listify(expr.get(keys.0))
    cond:
      key-str == '(any)': class-union(table val allow-barrier)
      key-str == '(---)': class-diff(table val allow-barrier)

defn class-union(table items allow-barrier):
  classes =: items.map(\(class-of(table _ allow-barrier)))
  when-not some(nil? classes):
    normalize-ranges: apply(concat classes)

defn class-diff(table items allow-barrier):
  classes =: items.map(\(class-of(table _ allow-barrier)))
  when-not some(nil? classes):
    reduce range-subtract: classes.0 rest(classes)

defn normalize-ranges(ranges):
  sorted =: sort-by(first ranges)
  init =: +[]
  reduce _ init sorted:
    fn(acc r):
      prev =: acc.$
      if prev && (first(r) <= prev.1.++):
        then: acc:pop.conj([prev.0 max(prev.1 last(r))])
        else: acc.conj(vec(r))

defn range-subtract(a-ranges b-ranges):
  reduce _ a-ranges b-ranges:
    fn(acc b):
      acc.mapcat(\(subtract-one(_ b))):V

defn subtract-one([lo hi] [blo bhi]):
  cond:
    (bhi < lo) || (blo > hi): +[[lo hi]]
    (blo <= lo) && (bhi >= hi): +[]
    (blo > lo) && (bhi < hi): +[[lo blo.--] [bhi.++ hi]]
    blo <= lo: +[[bhi.++ hi]]
    else: +[[lo blo.--]]

defn hex-int(h):
  Long/parseLong: h 16

defn dump-classes(spec-text):
  spec =: yaml/load(spec-text)
  table =: build-class-table(spec)
  names =: spec:keys.map(key-name).filter(\(_.starts?(':').!))
  each name names:
    ranges =: table.get(name)
    when ranges:
      say: "$name:\ $(ranges.map(fmt-range):joins)"

defn fmt-range([lo hi]):
  if lo == hi:
    then: format('[%X]' lo)
    else: format('[%X-%X]' lo hi)

defn gen-rule(spec nums comments classes name):
  base-rule =: kget(spec name)
  setm-rule =: setm-and-rule(base-rule)
  setm =: setm-rule.0
  rule =: setm-rule.1
  rule :if map?(rule) =:
    rule.kdissoc('(...)')
  num-key =: nums.$name
  num :if num-key =:
    key-name(num-key).drop(1):join
  comment =: comments.$num || ''
  rule-name-str =: rule-name(name)
  debug-args =: gen-debug-args(spec name)
  rule-args =: gen-rule-args(spec name)
  args =: rule-args-list(spec name)
  ctx =: new-ctx().assoc(
    :num num
    :setm setm
    :args args
    :classes classes
    :rule-name name)
  rule-body =: indent(gen(ctx rule))
  setm-close =: gen-setm-close(setm)
  has-flip =: has-text?(rule-body 'p/flip')
  cacheable =: (setm == '') && has-flip.!
  ranges =: classes && classes.get(name)
  gate =: GATE-FIRST.get(name)
  cond:
    name == 'b-break':
      # Fused in the engine: CRLF | CR | LF as one leaf matcher (see
      # p/brk), replacing the 3-alternative combinator tree that
      # tried CR twice before matching the common LF.
      str: |+
        ${comment}(def $rule-name-str
          (let [body (p/brk nil)]
            (p/leaf*
             (name* "$rule-name-str"
               (fn ${rule-name-str}-fn [parser]
                 (when DEBUG (debug-rule "$rule-name-str"))
                 (body parser))
               nil))))
    name == 'nb-ns-plain-in-line':
      # Fused in the engine: the ( s-white* ns-plain-char(c) )* line
      # scan as one leaf matcher per safe-class (see p/plain-in-line
      # for the semantics and the FUSE-BARRIER soundness argument).
      # ns-plain-safe-out = ns-char; ns-plain-safe-in = ns-char minus
      # c-flow-indicator; context mapping per ns-plain-safe [127].
      gen-plain-in-line-rule: comment rule-name-str classes
    name == 'nb-single-one-line':
      # Fused single-quoted line scans (see p/squo-scan): keep true =
      # nb-single-char*, keep false = ( s-white* ns-single-char )*
      # with trailing whites dropped. No rule in either subtree has
      # receiver callbacks.
      gen-squo-scan-rule: comment rule-name-str classes 'true'
    name == 'nb-ns-single-in-line':
      gen-squo-scan-rule: comment rule-name-str classes 'false'
    ranges:
      gen-class-rule:
        comment
        rule-name-str
        ranges
        contains?(FUSE-BARRIER name).!
    gate && cacheable && (args.# == 0):
      # Gated variant of the delay branch below: the lookahead
      # predicate runs per invocation, before the cached tree.
      str: |+
        ${comment}(def $rule-name-str
          (let [body (delay
                       (let [parser nil]
          $rule-body))]
            (name* "$rule-name-str"
              (fn ${rule-name-str}-fn [parser]
                (when DEBUG (debug-rule "$rule-name-str"))
                (if (p/ahead? parser $gate)
                  @body
                  false))
              nil)))
    cacheable && (args.# == 0):
      # No runtime args and a pure-constructor body: build the
      # combinator tree once on first use (delay defers evaluation
      # past the forward declarations). Constructors ignore their
      # parser argument, so it is shadowed with nil.
      str: |+
        ${comment}(def $rule-name-str
          (let [body (delay
                       (let [parser nil]
          $rule-body))]
            (name* "$rule-name-str"
              (fn ${rule-name-str}-fn [parser]
                (when DEBUG (debug-rule "$rule-name-str"))
                @body)
              nil)))
    cacheable:
      # Runtime args are embedded in the tree, so cache one tree per
      # distinct argument vector (n is a small int or nil, c one of a
      # few context strings).
      str: |+
        ${comment}(def $rule-name-str
          (let [cache (volatile! {})]
            (name* "$rule-name-str"
              (fn ${rule-name-str}-fn $rule-args
                (when DEBUG (debug-rule "$rule-name-str"$debug-args))
                (or (get @cache [$(args:joins)])
                    (let [body
        $rule-body]
                      (vswap! cache assoc [$(args:joins)] body)
                      body)))
              nil)))
    else:
      # set-m rules evaluate auto-detect at call time and flip rules
      # execute at construction; both must rebuild per invocation.
      str: |+
        ${comment}(def $rule-name-str
          (name* "$rule-name-str"
            (fn ${rule-name-str}-fn $rule-args$setm
              (when DEBUG (debug-rule "$rule-name-str"$debug-args))
          $rule-body$setm-close)
            nil))

defn gen-plain-in-line-rule(comment name classes):
  ns-ranges =: classes.get('ns-char')
  in-items =: +['ns-char' 'c-flow-indicator']
  safe-in =: class-diff(classes in-items true)
  ns-flat =: flat-ranges(ns-ranges)
  str: |+
    ${comment}(def $name
      (let [out-body (p/plain-in-line nil [$ns-flat] [$ns-flat])
            in-body (p/plain-in-line nil [$(flat-ranges(safe-in))] [$ns-flat])]
        (name* "$name"
          (fn ${name}-fn [parser c]
            (when DEBUG (debug-rule "$name", c))
            (case c
              ("flow-out" "block-key") out-body
              ("flow-in" "flow-key") in-body
              nil))
          nil)))

defn gen-squo-scan-rule(comment name classes keep):
  items =: +['nb-json' 'x27']
  ranges =: class-diff(classes items true)
  str: |+
    ${comment}(def $name
      (let [body (p/squo-scan nil [$(flat-ranges(ranges))] $keep)]
        (p/leaf*
         (name* "$name"
           (fn ${name}-fn [parser]
             (when DEBUG (debug-rule "$name"))
             (body parser))
           nil))))

# Class rules build their fused matcher once and invoke it directly.
# Non-barrier class rules are additionally leaf-marked: call may skip
# their frame entirely when no receiver callback can fire there.
# Barrier rules keep normal frames so their callbacks fire per call.
defn gen-class-rule(comment name ranges leaf):
  matcher =: gen-matcher(ranges)
  if leaf:
    then:
      str: |+
        ${comment}(def $name
          (let [body $matcher]
            (p/leaf*
             (name* "$name"
               (fn ${name}-fn [parser]
                 (when DEBUG (debug-rule "$name"))
                 (body parser))
               nil))))
    else:
      str: |+
        ${comment}(def $name
          (let [body $matcher]
            (name* "$name"
              (fn ${name}-fn [parser]
                (when DEBUG (debug-rule "$name"))
                (body parser))
              nil)))

defn gen-matcher(ranges):
  cond:
    (ranges.# == 1) && (ranges.0.0 == ranges.0.1):
      "(p/chr nil $(gen-hex-code(format('%X' ranges.0.0))))"
    ranges.# == 1:
      str:
        =>: "(p/rng nil $(gen-hex-code(format('%X' ranges.0.0)))"
        =>: " $(gen-hex-code(format('%X' ranges.0.1))))"
    else:
      "(p/chars nil [$(flat-ranges(ranges))])"

defn flat-ranges(ranges):
  ranges.mapcat(a).map(\(format('0x%X' _))):joins

# Rules whose receiver-callback chains pass through combinator frames
# (see receiver.cljc chain keys like c_flow_sequence__all__x5b): never
# fuse subexpressions inside them, their frame structure is load-bearing.
LIVE-CHAIN-RULES =:
  \{'c-flow-mapping' 'c-flow-sequence' 'l-nb-literal-text'
    's-nb-folded-text' 's-nb-spaced-text' 's-l+block-collection'}

defn gen-group-or-chars(ctx val kind):
  items =: listify(val)
  fusable =:
    ctx.classes &&
    contains?(LIVE-CHAIN-RULES ctx.rule-name).!
  ranges =:
    when fusable:
      if kind == 'any':
        then: class-union(ctx.classes items false)
        else: class-diff(ctx.classes items false)
  if ranges:
    then: "(p/chars parser [$(flat-ranges(ranges))])"
    else: gen-group(ctx val kind)

defn setm-and-rule(rule):
  cond:
    map?(rule) && kget(rule '(->m)'):
      +[gen-setm(false) kdissoc(rule '(->m)')]
    map?(rule) && kget(rule '(m>0)'):
      +[gen-setm(true) kdissoc(rule '(m>0)')]
    else:
      +['' rule]

defn gen-setm-close(setm):
  cond:
    has-text?(setm 'pos? m'): ")\n      false))"
    has-text?(setm 'if-let'): ")\n      false)"
    has-text?(setm 'let [m'): ')'
    else: ''

defn gen-rule-args(spec name):
  rule =: kget(spec name)
  if-not map?(rule):
    then: '[parser]'
    else:
      args =: kget(rule '(...)')
      if args:
        then:
          args =: listify(args)
          joined =: args:joins
          =>: "[parser $joined]"
        else: '[parser]'

defn gen-debug-args(spec name):
  rule =: kget(spec name)
  if-not map?(rule):
    then: ''
    else:
      args =: kget(rule '(...)')
      if args:
        then:
          args =: listify(args)
          =>: ", $(args.join(', '))"
        else: ''

defn rule-args-list(spec name):
  rule =: kget(spec name)
  if map?(rule):
    then:
      args =: kget(rule '(...)')
      if args:
        listify(args)
        +[]
    else: +[]

defn gen-setm(return-false):
  if return-false:
    then: |2-

        ;; m must be > 0 (JS treats 0 as falsy, Clojure doesn't)
        (let [m (p/call parser [auto_detect_indent, n] "number")]
          (if (and m (pos? m))
          (do
    else: |2-

        (let [m (p/call parser [auto_detect_indent, n] "number")]

defn gen(ctx rule):
  cond:
    map?(rule): gen-from-hash(ctx rule)
    sequential?(rule): gen-from-array(ctx rule)
    string?(rule): gen-from-string(ctx rule)
    number?(rule): rule:S
    nil?(rule): gen-null()
    else:
      throw-rule-error(ctx 'unknown rule type' +{:rule rule})

defn gen-from-hash(ctx rule):
  set-expr =: kget(rule '(set)')
  keys =: rule:keys
  when (keys.# > 1) && nil?(set-expr):
    when-not kget(rule '(...)') || kget(rule '(->m)') || kget(rule '(m>0)'):
      throw-rule-error(ctx 'unknown keys' +{:keys keys})
  key =: keys.0
  key-str =: key-name(key)
  val =: rule.$key
  cond:
    re-matches(/^\(\{(.)\}\)$/ key-str):
      n =: re-matches(/^\(\{(.)\}\)$/ key-str).1
      gen-rep: ctx val n n
    re-matches(/^(([bcls]|n[bs]|in|seq)[-+][-+a-z0-9]+)$/ key-str):
      gen-call: ctx key-str val
    key-str == 'auto-detect': gen-call(ctx key-str val)
    key-str == '(any)': gen-group-or-chars(ctx val 'any')
    key-str == '(all)': gen-group(ctx val 'all')
    key-str == '(---)': gen-group-or-chars(ctx val 'but')
    key-str == '(+++)': gen-rep(ctx val 1 nil)
    key-str == '(***)': gen-rep(ctx val 0 nil)
    key-str == '(???)': gen-rep(ctx val 0 1)
    key-str == '(<<<)': gen-may(ctx val)
    key-str == '(===)': gen-chk(ctx val '=')
    key-str == '(!==)': gen-chk(ctx val '!')
    key-str == '(<==)': gen-chk(ctx val '<=')
    key-str == '(+)': gen-add(ctx val)
    key-str == '(-)': gen-sub(ctx val)
    key-str == '(<)': gen-lt(ctx val)
    key-str == '(<=)': gen-le(ctx val)
    key-str == '(case)': gen-case(ctx val)
    key-str == '(flip)': gen-flip(ctx val)
    key-str == '(max)': gen-max(ctx val)
    key-str == '(if)': gen-if(ctx val set-expr)
    key-str == '(set)': gen-set(ctx val)
    key-str == '(ord)': gen-ord(ctx val)
    key-str == '(len)': gen-len(ctx val)
    key-str == '(exclude)': gen-exclude(ctx val)
    else:
      throw-rule-error(ctx 'unknown hash rule' +{:rule rule, :key key-str})

defn gen-from-array(ctx rule):
  if (rule.# == 2) && string?(rule.0) && rule.0.starts?('x'):
    then:
      gen-method-call:
        ctx
        'rng'
        gen-hex-code(rule.0.drop(1):join)
        gen-hex-code(rule.1.drop(1):join)
    else:
      throw-rule-error: ctx 'Unknown array rule type' +{:rule rule}

defn gen-from-string(ctx rule):
  hex-match =: re-matches(/^x([0-9A-F]+)$/ rule)
  angle-match =: re-matches(/^<(\w.+)>$/ rule)
  context-values =:: [auto-detect, strip, clip, keep]
  context-value =:
    re-matches(/^(flow|block)-(in|out|key)$/ rule) ||
    contains?(set(context-values) rule)
  cond:
    hex-match:
      gen-method-call: ctx 'chr' gen-hex-code(hex-match.1)
    re-matches(/^(?:b|c|e|l|nb|ns|s)(?:[-+][a-z0-9]+)+$/ rule):
      gen-method-ref: rule-name(rule)
    rule.# == 1:
      gen-single-char: ctx rule
    context-value:
      "\"$rule\""
    angle-match:
      gen-method-ref: rule-name(angle-match.1)
    rule == '(match)':
      '(p/match parser)'
    else:
      throw-rule-error: ctx 'Unknown string rule type' +{:rule rule}

defn gen-single-char(ctx rule):
  method-names =:: [m, t]
  implicit-method =:
    contains?(set(method-names) rule) &&
    contains?(set(ctx.args) rule).! &&
    ctx.setm.!
  cond:
    rule == "'": gen-method-call(ctx 'chr' "\"'\"")
    rule == "\\": gen-method-call(ctx 'chr' '"\\"')
    rule == '"': gen-method-call(ctx 'chr' '"\""')
    rule == '{': gen-method-call(ctx 'chr' '"\u007B"')
    rule == '}': gen-method-call(ctx 'chr' '"\u007D"')
    rule == '#': gen-method-call(ctx 'chr' '"\u0023"')
    rule == '@': gen-method-call(ctx 'chr' '"\u0040"')
    rule == '`': gen-method-call(ctx 'chr' '"\u0060"')
    ctx.arg:
      if implicit-method:
        then: gen-method-call(ctx rule)
        else: gen-var-value(rule)
    else:
      gen-method-call: ctx 'chr' "\"$rule\""

defn gen-group(ctx items kind):
  group-ctx =:
    ctx.assoc(:group true :rep-count atom(0))
  generated =: items.map(\(gen(group-ctx _)))
  gen-method-call: group-ctx kind generated*

# Reps over a pure character class fuse into one scanning matcher.
# Excluded: the live-chain rules (rep frames feed callback chains) and
# s-indent-lt/le, whose p/match "" invariant depends on the rep frame's
# final zero-width bookkeeping.
REP-FUSE-EXCLUDE =: \{'s-indent-lt' 's-indent-le'}

# Live-chain rules whose class reps may fuse anyway, with the rep's
# own frame name ("rep"/"rep2") passed to chars-rep so the chain
# callback anchored on that frame (got__l_nb_literal_text__all__rep2,
# got__s_nb_folded_text__all__rep, got__s_nb_spaced_text__all__rep)
# still resolves and fires with the same matched text. Sound because
# no callback chain extends below these rep frames (nb-char has no
# callbacks anywhere).
LIVE-CHAIN-REP-FUSE =:
  \{'l-nb-literal-text' 's-nb-folded-text' 's-nb-spaced-text'}

# Rules whose class reps may fuse THROUGH the s-white/ns-char barrier.
# The barrier protects the scalar-mode got__s_white/got__ns_char
# handlers (folded-text :first capture); s-separate-in-line never runs
# between a folded/spaced line's :first capture and its text-rep
# callback (those productions are s-indent ns-char/s-white nb-char*,
# with no separation inside), so its whites are never observed.
REP-FUSE-BARRIER-OK =: \{'s-separate-in-line'}

defn gen-rep(ctx rule min max):
  rep-num =: swap(ctx.rep-count inc)
  allow-barrier =: contains?(REP-FUSE-BARRIER-OK ctx.rule-name)
  live-fuse =: contains?(LIVE-CHAIN-REP-FUSE ctx.rule-name)
  ranges =:
    when rep-fusable?(ctx) || live-fuse:
      class-of(ctx.classes rule allow-barrier)
  cond:
    ranges && live-fuse:
      rep-name =:
        if rep-num > 1:
          then: 'rep2'
          else: 'rep'
      str:
        =>: "(p/chars-rep parser $(gen-limit(min)), $(gen-limit(max)),"
        =>: "\n       [$(flat-ranges(ranges))] \"$rep-name\")"
    ranges: +
      "(p/chars-rep parser $(gen-limit(min)), $(gen-limit(max)),
       [$(flat-ranges(ranges))])"
    else: gen-rep-call(ctx rule min max rep-num)

defn rep-fusable?(ctx):
  ctx.classes.? &&
  contains?(LIVE-CHAIN-RULES ctx.rule-name).! &&
  contains?(REP-FUSE-EXCLUDE ctx.rule-name).!

defn gen-rep-call(ctx rule min max rep-num):
  rep-fn =:
    if rep-num > 1:
      then: 'rep2'
      else: 'rep'
  rep =:
    gen-method-call(ctx rep-fn gen-limit(min) gen-limit(max) gen(ctx rule))
  rep: .replace(/\(\n  (-?\d+),\n  (nil|-?\d+),/ '($1, $2,')
    .replace(/\)\n\)/ '))')

defn gen-call(ctx call args):
  args =: listify(args)
  list-str =: args.map(\(gen-arg(ctx _))).join(', ')
  ref =: gen-method-ref(rule-name(call))
  =>: "[$ref, $list-str]"

defn gen-may(ctx rule):
  gen-method-call: ctx 'may' gen(ctx rule)

defn gen-chk(ctx rule kind):
  gen-method-call: ctx 'chk' "\"$kind\"" gen(ctx rule)

defn gen-case(ctx obj):
  var-name =: kget(obj 'var')
  obj =: kdissoc(obj 'var')
  gen-method-call: ctx 'case*' gen-var-value(var-name) gen-hash(ctx obj)

defn gen-flip(ctx obj):
  var-name =: kget(obj 'var')
  obj =: kdissoc(obj 'var')
  pairs =: obj.map(\(gen-flip-pair(_))):join
  hash-str =:
    str:
      =>: '{'
      =>: pairs
      =>: "\n}"
  gen-method-call: ctx 'flip' gen-var-value(var-name) hash-str

defn gen-flip-pair([k v]):
  key-str =: key-name(k)
  =>: "\n  \"$key-str\"$gen-pair-sep()$gen-arg(new-ctx() v),"

defn gen-hash(ctx obj):
  pairs =: obj.map(\(gen-hash-pair(ctx _))):join
  =>: "{$pairs\n}"

defn gen-hash-pair(ctx [k v]):
  rule =: gen(ctx v)
    .replace(/\s+/ ' ')
    .replace(/,\ \)/ ' )')
  key-str =: key-name(k)
  =>: "\n  \"$key-str\"$gen-pair-sep()$rule,"

defn gen-max(ctx max-val):
  gen-method-call: ctx 'max*' max-val

defn gen-if(ctx cond-expr set-expr):
  gen-method-call: ctx 'if*' gen(ctx cond-expr) gen-set(ctx set-expr)

defn gen-set(ctx [vari expr]):
  gen-method-call: ctx 'set*' "\"$vari\"" gen(ctx expr)

defn gen-ord(ctx expr):
  gen-method-call: ctx 'ord' gen(ctx expr)

defn gen-len(ctx expr):
  gen-method-call: ctx 'len' gen(ctx expr)

defn gen-exclude(ctx rule):
  gen-method-call: ctx 'exclude' gen(ctx rule)

defn gen-add(ctx [x y]):
  gen-method-call: ctx 'add' gen(ctx x) gen(ctx y)

defn gen-sub(ctx [x y]):
  gen-method-call: ctx 'sub' gen(ctx x) gen(ctx y)

defn gen-lt(ctx [x y]):
  gen-method-call: ctx 'lt' gen-arg(ctx x) gen-arg(ctx y)

defn gen-le(ctx [x y]):
  gen-method-call: ctx 'le' gen-arg(ctx x) gen-arg(ctx y)

defn gen-arg(ctx arg):
  gen: ctx.assoc(:arg true) arg

defn gen-method-call(ctx method *args):
  result =: gen-method-call-args(ctx args)
  args-str =: result.0
  sep =: result.1
  str:
    =>: "(p/$method parser"
    when args-str:seq: "$sep $args-str"
    when sep == "\n": "\n"
    =>: ')'

defn gen-method-call-args(ctx args):
  multiline =:
    ctx.group ||
    some(\(string?(_) && has-text?(_ "\n")) args)
  if multiline: +
    [args.map(\(indent(string-val(_)))).join(",\n") "\n"]
    [args.map(string-val).join(', ') '']

defn gen-method-ref(name):
  parser-fns =:: [start_of_line, end_of_stream]
  cond:
    name == 'auto_detect_indent': "[$name, n]"
    contains?(set(parser-fns) name):
      "(p/$(name.replace('_' '-')) parser)"
    else: name

defn gen-hex-code(hex):
  code-point =: Long/parseLong(hex 16)
  if code-point > 0xFFFF:
    then: "(from-code-point 0x$hex)"
    else:
      padded =:
        if hex.# < 4:
          then: str(repeat((4 - hex.#) '0'):join hex)
          else: hex
      str: |-
        "\u$padded"

defn gen-null(): 'nil'

defn gen-pair-sep(): ' '

defn gen-var-value(var-name): var-name

defn gen-limit(n):
  cond:
    number?(n): n
    nil?(n): 'nil'
    else: n

defn get-comments(spec-text):
  lines =: spec-text.split("\n")
  init-map =: +{}
  init =: +[init-map nil nil]
  state =:
    reduce:
      add-comment-line
      init
      lines
  first: state

defn add-comment-line([comments current-num current-comment] line):
  num-match =: re-matches(/^:(\d+):.*/ line)
  cond:
    num-match:
      num =: num-match.1
      comments =:
        if current-num:
          then: comments.assoc(current-num current-comment)
          else: comments
      =>: +[comments num ";; [$num]\n"]
    current-num && line.starts?('# '):
      comment-text =: line.drop(2):join.replace("\\" "\\\\")
      =>: +[comments current-num "${current-comment};; $comment-text\n"]
    current-num:
      comments =: comments.assoc(current-num current-comment)
      =>: +[comments nil nil]
    else:
      =>: +[comments nil nil]

defn build-nums(spec):
  init =: +{}
  reduce:
    build-num
    init
    spec

defn build-num(acc [k v]):
  if key-name(k).starts?(':'):
    then: acc.assoc(v k)
    else: acc

defn rule-name(name):
  name: .replace(/[-+]/ '_')

defn indent(text n=1):
  prefix =: (n * 2) * ' '
  text: .replace(/(?m)^(.)/ "${prefix}$1")

defn string-val(o):
  if nil?(o):
    then: 'nil'
    else: o:S

defn key-name(k):
  if keyword?(k):
    then: name(k)
    else: k:S

defn kget(m k):
  m.$k || m.get(k:K)

defn has-text?(s part):
  not(nil?(index(s part)))

defn kdissoc(m *ks):
  all-ks =: ks + ks.map(K)
  dissoc: m all-ks*

defn listify(x):
  if sequential?(x):
    then: x
    else: +[x]

defn new-ctx():
  args =: +[]
  ctx =: +{}
  ctx =: ctx.assoc(:num nil)
  ctx =: ctx.assoc(:arg false)
  ctx =: ctx.assoc(:group false)
  ctx =: ctx.assoc(:args args)
  ctx =: ctx.assoc(:setm '')
  ctx =: ctx.assoc(:classes nil)
  ctx: .assoc(:rep-count REP-COUNT)

defn throw-rule-error(ctx message data):
  throw:
    ex-info:
      =>: "[$(ctx.num)] $message"
      =>: data
